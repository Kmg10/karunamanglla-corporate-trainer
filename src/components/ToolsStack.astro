---
import { tools } from '../data/tools';
---

<div class="reveal">
  <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-stone-500 mb-4">Tools &amp; platforms taught</p>
  <div class="grid grid-cols-5 sm:grid-cols-10 gap-3">
    {tools.map((tool) => (
      <div class="flex flex-col items-center gap-2 group" title={tool.name}>
        <div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center p-2 border border-stone-200/20 group-hover:border-brand-500/30 transition-colors">
          <img
            src={tool.logo}
            alt={`${tool.name} logo`}
            width={tool.width}
            height={tool.height}
            class="w-7 h-7 object-contain"
            loading="lazy"
            draggable="false"
          />
        </div>
        <span class="text-[9px] text-stone-500 text-center leading-tight">{tool.name}</span>
      </div>
    ))}
  </div>
</div>
