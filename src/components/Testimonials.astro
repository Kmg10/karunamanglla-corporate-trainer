---
const testimonials = [
  {
    quote: 'Karuna bridges the gap between theory and production. Her sessions on survival modeling and causal inference turned our analysts into practicing data scientists — not just notebook runners.',
    name: 'Mind Share Knowledge Sessions',
    org: 'JioStar Analytics',
    type: 'Corporate upskilling',
  },
  {
    quote: 'Exceptional dedication and work ethic. Her guidance and mentorship is commendable — she fosters collaboration and end-to-end ownership across every cohort she runs.',
    name: 'Direct Manager',
    org: 'JioStar (Disney+ Hotstar)',
    type: 'Leadership',
  },
  {
    quote: 'Great at articulating complex analysis to both technical and business audiences. Training that lands with every stakeholder level — from fresh grads to senior leaders.',
    name: 'Team & Stakeholders',
    org: 'JioStar (Disney+ Hotstar)',
    type: 'Cross-functional',
  },
  {
    quote: 'The GenAI bootcamp was exactly what our team needed — prompt engineering, RAG, and agents we could deploy on Monday. Hands-on from hour one, not slide decks.',
    name: 'Engineering Lead',
    org: 'Edtech cohort',
    type: 'GenAI program',
  },
  {
    quote: 'Beyond Python and SQL, Karuna helped our learners build portfolios and interview confidence. Graduates left job-ready — not just technically skilled.',
    name: 'Program Director',
    org: 'Career acceleration partner',
    type: 'Career readiness',
  },
  {
    quote: 'Custom curriculum aligned to our stack and maturity. Pre/post assessments gave our L&D team the ROI evidence we needed for leadership buy-in.',
    name: 'L&D Partner',
    org: 'Enterprise academy',
    type: 'Corporate L&D',
  },
];
---

<section id="testimonials" class="py-20 bg-stone-900/25 border-y border-stone-800/80">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal mb-12">
      <p class="section-eyebrow">Testimonials</p>
      <h2 class="section-heading">What partners and learners say.</h2>
      <p class="text-stone-500 max-w-2xl mt-2">
        Feedback from corporate L&amp;D partners, engineering leaders, and cohort participants across edtech and enterprise programs.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {testimonials.map((t, i) => (
        <div class="reveal card-hover flex flex-col" style={`transition-delay: ${i * 50}ms`}>
          <svg class="w-7 h-7 text-brand-500/30 mb-3 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
          <blockquote class="text-sm text-stone-400 italic leading-relaxed mb-4 flex-1">"{t.quote}"</blockquote>
          <div class="border-t border-stone-800 pt-4 mt-auto">
            <p class="text-xs font-semibold text-stone-200">{t.name}</p>
            <p class="text-[10px] text-stone-600 mt-0.5">{t.org}</p>
            <span class="chip-muted text-[10px] mt-2">{t.type}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
