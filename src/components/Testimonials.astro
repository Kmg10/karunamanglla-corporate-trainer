---
import { feedbackStats, learnerTestimonials, codingNinjasTribute } from '../data/learner-feedback';

const postcardColors = ['#fef3c7', '#fce7f3', '#e0f2fe', '#dcfce7', '#ede9fe', '#ffedd5'];
---

<section id="testimonials" class="py-20 bg-stone-900/25 border-y border-stone-800/80 overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal mb-10 text-center">
      <p class="section-eyebrow">Testimonials</p>
      <h2 class="section-heading">Admiration &amp; praise from learners.</h2>
      <p class="text-stone-500 max-w-2xl mx-auto mt-2">
        Not just feedback — heartfelt admiration from live cohorts across Coding Ninjas, IIT partnerships, and enterprise programs.
        {feedbackStats.notes.toLocaleString()}+ notes · <span class="text-brand-400 font-semibold">{feedbackStats.avgRating}+</span> average rating.
      </p>
    </div>

    <div class="reveal grid grid-cols-1 sm:grid-cols-3 gap-4 mb-14 max-w-3xl mx-auto">
      {[
        { icon: '🎓', value: `${feedbackStats.learners}+`, label: 'Learners mentored' },
        { icon: '💬', value: `${feedbackStats.notes.toLocaleString()}+`, label: 'Notes of admiration' },
        { icon: '⭐', value: `${feedbackStats.avgRating}+`, label: 'Average rating' },
      ].map((s) => (
        <div class="card text-center p-5 border-brand-500/15">
          <span class="text-2xl mb-2 block">{s.icon}</span>
          <p class="text-2xl font-display font-semibold text-stone-50 tabular-nums">{s.value}</p>
          <p class="text-[11px] text-stone-500 mt-1">{s.label}</p>
        </div>
      ))}
    </div>

    <!-- Postcard wall -->
    <div class="reveal postcards-wall columns-1 sm:columns-2 lg:columns-3 gap-5 mb-14">
      {learnerTestimonials.map((t, i) => (
        <article
          class="postcard break-inside-avoid mb-5"
          style={`--rotate: ${t.rotate}deg; --paper: ${postcardColors[i % postcardColors.length]}`}
        >
          <div class="postcard-tape" aria-hidden="true"></div>
          <div class="postcard-inner">
            <p class="postcard-quote">"{t.quote}"</p>
            <div class="postcard-footer">
              <p class="postcard-name">{t.name}</p>
              <p class="postcard-org">{t.org}</p>
              <span class="postcard-tag">{t.type}</span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Team tribute postcard -->
    <div class="reveal max-w-lg mx-auto">
      <article class="postcard postcard-featured" style="--rotate: 0deg; --paper: #fef9c3">
        <div class="postcard-tape postcard-tape-center" aria-hidden="true"></div>
        <div class="postcard-inner text-center">
          <p class="text-rose-500 text-sm font-semibold mb-3">❤️ With Gratitude</p>
          <p class="postcard-quote text-center">"{codingNinjasTribute.quote}"</p>
          <div class="postcard-footer border-0 pt-4">
            <p class="postcard-name">{codingNinjasTribute.name}</p>
            <p class="postcard-org">{codingNinjasTribute.org}</p>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .postcards-wall {
    perspective: 800px;
  }
  .postcard {
    position: relative;
    transform: rotate(var(--rotate));
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .postcard:hover {
    transform: rotate(0deg) scale(1.02);
    z-index: 10;
  }
  .postcard-inner {
    background: var(--paper);
    border-radius: 4px;
    padding: 1.25rem 1.25rem 1rem;
    box-shadow:
      2px 4px 12px rgba(0, 0, 0, 0.35),
      0 1px 0 rgba(255, 255, 255, 0.6) inset;
    border: 1px solid rgba(0, 0, 0, 0.06);
    min-height: 140px;
    display: flex;
    flex-direction: column;
  }
  .postcard-tape {
    position: absolute;
    top: -8px;
    left: 24px;
    width: 56px;
    height: 18px;
    background: rgba(255, 255, 220, 0.75);
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
    transform: rotate(-4deg);
    z-index: 2;
  }
  .postcard-tape-center {
    left: 50%;
    transform: translateX(-50%) rotate(-2deg);
  }
  .postcard-quote {
    font-family: 'Caveat', 'Segoe Script', cursive;
    font-size: 1.15rem;
    line-height: 1.45;
    color: #292524;
    flex: 1;
    margin-bottom: 0.75rem;
  }
  .postcard-footer {
    border-top: 1px dashed rgba(0, 0, 0, 0.15);
    padding-top: 0.65rem;
    margin-top: auto;
  }
  .postcard-name {
    font-size: 0.7rem;
    font-weight: 700;
    color: #44403c;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .postcard-org {
    font-size: 0.65rem;
    color: #78716c;
    margin-top: 0.15rem;
  }
  .postcard-tag {
    display: inline-block;
    margin-top: 0.4rem;
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #a8a29e;
    background: rgba(0, 0, 0, 0.05);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
  }
  .postcard-featured .postcard-inner {
    padding: 1.75rem 1.5rem;
  }
  .postcard-featured .postcard-quote {
    font-size: 1.25rem;
  }
</style>
