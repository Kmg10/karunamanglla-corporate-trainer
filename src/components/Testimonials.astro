---
import { feedbackStats, learnerTestimonials, codingNinjasTribute } from '../data/learner-feedback';
---

<section id="testimonials" class="py-20 bg-stone-900/25 border-y border-stone-800/80">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal mb-10">
      <p class="section-eyebrow">Testimonials</p>
      <h2 class="section-heading">Heartfelt tributes from learners.</h2>
      <p class="text-stone-500 max-w-2xl mt-2">
        Real feedback from live cohorts across Coding Ninjas, IIT partnerships, and enterprise programs —
        {feedbackStats.notes.toLocaleString()}+ written notes, {feedbackStats.avgRating} average session rating.
      </p>
    </div>

    <div class="reveal grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12">
      {[
        { icon: '🎓', value: `${feedbackStats.learners}+`, label: 'Learners mentored' },
        { icon: '💬', value: `${feedbackStats.notes.toLocaleString()}+`, label: 'Heartfelt feedback notes' },
        { icon: '⭐', value: String(feedbackStats.avgRating), label: 'Average lecture rating' },
      ].map((s) => (
        <div class="card text-center p-6 border-brand-500/15">
          <span class="text-2xl mb-2 block">{s.icon}</span>
          <p class="text-3xl font-display font-semibold text-stone-50 tabular-nums">{s.value}</p>
          <p class="text-xs text-stone-500 mt-1">{s.label}</p>
        </div>
      ))}
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
      {learnerTestimonials.map((t, i) => (
        <div class="reveal card-hover flex flex-col" style={`transition-delay: ${i * 50}ms`}>
          <svg class="w-7 h-7 text-brand-500/40 mb-3 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
          <blockquote class="text-sm text-stone-300 italic leading-relaxed mb-4 flex-1">"{t.quote}"</blockquote>
          <div class="border-t border-stone-800 pt-4 mt-auto">
            <p class="text-xs font-semibold text-stone-200">{t.name}</p>
            <p class="text-[10px] text-stone-600 mt-0.5">{t.org}</p>
            <span class="chip-muted text-[10px] mt-2">{t.type}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="reveal card max-w-3xl mx-auto text-center p-8 md:p-10 border-brand-500/20 bg-gradient-to-b from-brand-950/20 to-stone-900/40">
      <p class="text-brand-400 text-sm font-semibold mb-3">❤️ With Gratitude</p>
      <blockquote class="text-base text-stone-300 italic leading-relaxed mb-5">
        "{codingNinjasTribute.quote}"
      </blockquote>
      <p class="text-sm font-semibold text-stone-100">{codingNinjasTribute.name}</p>
      <p class="text-xs text-stone-500 mt-1">{codingNinjasTribute.org}</p>
    </div>
  </div>
</section>
