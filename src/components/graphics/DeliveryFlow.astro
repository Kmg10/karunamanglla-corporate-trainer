---
const steps = [
  { x: 60, label: 'Diagnose', icon: '?' },
  { x: 240, label: 'Design', icon: '✎' },
  { x: 420, label: 'Deliver', icon: '▶' },
  { x: 600, label: 'Measure', icon: '✓' },
];
---

<svg class="w-full h-auto max-w-4xl mx-auto" viewBox="0 0 720 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <defs>
    <linearGradient id="df-arrow" x1="0" y1="0" x2="720" y2="0">
      <stop offset="0%" stop-color="#14b8a6" stop-opacity="0.3"/>
      <stop offset="100%" stop-color="#f59e0b" stop-opacity="0.3"/>
    </linearGradient>
  </defs>

  <path d="M 60 50 Q 180 20, 240 50 T 420 50 T 600 50 T 660 50" stroke="url(#df-arrow)" stroke-width="2" fill="none" stroke-dasharray="6 4"/>

  {steps.map((n) => (
    <g>
      <circle cx={n.x} cy="50" r="22" fill="#1c1917" stroke="#14b8a6" stroke-width="1.5" stroke-opacity="0.5"/>
      <text x={n.x} y="56" text-anchor="middle" fill="#14b8a6" font-size="16" font-family="system-ui">{n.icon}</text>
      <text x={n.x} y="90" text-anchor="middle" fill="#a8a29e" font-size="11" font-weight="600" font-family="system-ui">{n.label}</text>
    </g>
  ))}
</svg>
