<svg class="w-full h-auto max-w-md mx-auto" viewBox="0 0 400 280" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <defs>
    <linearGradient id="g1" x1="0" y1="0" x2="400" y2="280">
      <stop offset="0%" stop-color="#14b8a6" stop-opacity="0.3"/>
      <stop offset="100%" stop-color="#f59e0b" stop-opacity="0.1"/>
    </linearGradient>
  </defs>
  <rect width="400" height="280" rx="16" fill="url(#g1)" stroke="#292524" stroke-width="1"/>
  <!-- Globe arcs -->
  <ellipse cx="200" cy="130" rx="90" ry="90" stroke="#14b8a6" stroke-width="1.5" stroke-opacity="0.4"/>
  <ellipse cx="200" cy="130" rx="90" ry="35" stroke="#14b8a6" stroke-width="1" stroke-opacity="0.3"/>
  <ellipse cx="200" cy="130" rx="35" ry="90" stroke="#14b8a6" stroke-width="1" stroke-opacity="0.3"/>
  <line x1="110" y1="130" x2="290" y2="130" stroke="#14b8a6" stroke-width="1" stroke-opacity="0.2"/>
  <!-- Learner nodes -->
  {[
    { cx: 120, cy: 90, r: 6 },
    { cx: 280, cy: 100, r: 5 },
    { cx: 200, cy: 60, r: 7 },
    { cx: 160, cy: 180, r: 5 },
    { cx: 250, cy: 170, r: 6 },
    { cx: 200, cy: 200, r: 5 },
    { cx: 90, cy: 140, r: 4 },
    { cx: 310, cy: 150, r: 4 },
  ].map(n => (
    <circle cx={n.cx} cy={n.cy} r={n.r} fill="#14b8a6" fill-opacity="0.7"/>
  ))}
  <circle cx="200" cy="130" r="10" fill="#fbbf24" fill-opacity="0.9"/>
  <!-- Connection lines -->
  <line x1="200" y1="130" x2="120" y2="90" stroke="#14b8a6" stroke-width="1" stroke-opacity="0.25"/>
  <line x1="200" y1="130" x2="280" y2="100" stroke="#14b8a6" stroke-width="1" stroke-opacity="0.25"/>
  <line x1="200" y1="130" x2="160" y2="180" stroke="#14b8a6" stroke-width="1" stroke-opacity="0.25"/>
  <line x1="200" y1="130" x2="250" y2="170" stroke="#14b8a6" stroke-width="1" stroke-opacity="0.25"/>
  <text x="200" y="250" text-anchor="middle" fill="#a8a29e" font-size="11" font-family="system-ui">5,000+ learners · Global cohorts</text>
</svg>
