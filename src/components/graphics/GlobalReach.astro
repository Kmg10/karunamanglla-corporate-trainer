---
const regions = [
  { cx: 205, cy: 138, label: 'India', sub: 'Pan-India cohorts' },
  { cx: 95, cy: 108, label: 'United States', sub: 'North America' },
  { cx: 118, cy: 88, label: 'Canada', sub: 'North America' },
  { cx: 228, cy: 118, label: 'UAE', sub: 'Dubai · Abu Dhabi' },
  { cx: 168, cy: 72, label: 'Europe', sub: 'Virtual programs' },
  { cx: 198, cy: 198, label: 'South Africa', sub: 'Johannesburg · Cape Town' },
  { cx: 285, cy: 128, label: 'Singapore', sub: 'APAC' },
  { cx: 72, cy: 168, label: 'LATAM', sub: 'Virtual cohorts' },
];
---

<svg class="w-full h-auto max-w-md mx-auto" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <defs>
    <linearGradient id="g1" x1="0" y1="0" x2="400" y2="300">
      <stop offset="0%" stop-color="#14b8a6" stop-opacity="0.25"/>
      <stop offset="100%" stop-color="#f59e0b" stop-opacity="0.08"/>
    </linearGradient>
  </defs>
  <rect width="400" height="300" rx="16" fill="url(#g1)" stroke="#292524" stroke-width="1"/>

  <ellipse cx="200" cy="135" rx="92" ry="92" stroke="#14b8a6" stroke-width="1.5" stroke-opacity="0.45"/>
  <ellipse cx="200" cy="135" rx="92" ry="36" stroke="#14b8a6" stroke-width="1" stroke-opacity="0.3"/>
  <ellipse cx="200" cy="135" rx="36" ry="92" stroke="#14b8a6" stroke-width="1" stroke-opacity="0.3"/>
  <line x1="108" y1="135" x2="292" y2="135" stroke="#14b8a6" stroke-width="1" stroke-opacity="0.2"/>

  <circle cx="200" cy="135" r="9" fill="#fbbf24" fill-opacity="0.95"/>
  <line x1="200" y1="135" x2="205" y2="138" stroke="#fbbf24" stroke-width="1.5" stroke-opacity="0.6"/>

  {regions.map((r) => (
    <g>
      <line x1="200" y1="135" x2={r.cx} y2={r.cy} stroke="#14b8a6" stroke-width="1" stroke-opacity="0.22"/>
      <circle cx={r.cx} cy={r.cy} r="5" fill="#14b8a6" fill-opacity="0.75"/>
      <text x={r.cx} y={r.cy - 10} text-anchor="middle" fill="#e7e5e4" font-size="9" font-weight="600" font-family="system-ui">{r.label}</text>
      <text x={r.cx} y={r.cy + 18} text-anchor="middle" fill="#78716c" font-size="7" font-family="system-ui">{r.sub}</text>
    </g>
  ))}

  <text x="200" y="282" text-anchor="middle" fill="#a8a29e" font-size="10" font-family="system-ui">5,000+ learners · India · North America · UAE · South Africa &amp; beyond</text>
</svg>
