---
const nodes = [
  { x: 60, label: 'IIT / NPTEL', sub: 'Foundations' },
  { x: 180, label: 'IBM · Google', sub: 'Data Science' },
  { x: 320, label: 'Stanford · MIT', sub: 'ML & CS' },
  { x: 460, label: 'DeepLearning.AI', sub: 'GenAI · LLMs' },
  { x: 560, label: 'Microsoft', sub: 'Cloud AI' },
];
---

<svg class="w-full h-auto max-w-3xl mx-auto" viewBox="0 0 640 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <defs>
    <linearGradient id="cs-bar" x1="0" y1="0" x2="640" y2="0">
      <stop offset="0%" stop-color="#14b8a6"/>
      <stop offset="35%" stop-color="#3b82f6"/>
      <stop offset="65%" stop-color="#8b5cf6"/>
      <stop offset="100%" stop-color="#f59e0b"/>
    </linearGradient>
  </defs>
  <rect width="640" height="120" rx="16" fill="#1c1917" stroke="#292524" stroke-width="1"/>

  <rect x="40" y="50" width="560" height="8" rx="4" fill="url(#cs-bar)" opacity="0.6"/>

  {nodes.map((n) => (
    <g>
      <circle cx={n.x} cy="54" r="10" fill="#1c1917" stroke="#14b8a6" stroke-width="2"/>
      <circle cx={n.x} cy="54" r="4" fill="#14b8a6"/>
      <text x={n.x} y="88" text-anchor="middle" fill="#d6d3d1" font-size="10" font-weight="600" font-family="system-ui">{n.label}</text>
      <text x={n.x} y="102" text-anchor="middle" fill="#78716c" font-size="8" font-family="system-ui">{n.sub}</text>
    </g>
  ))}

  <text x="320" y="28" text-anchor="middle" fill="#a8a29e" font-size="11" font-family="system-ui">Credential spectrum — from IIT foundations to frontier AI</text>
</svg>
