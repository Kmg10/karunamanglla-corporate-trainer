---
import { deliveryTypes } from '../../data/delivery-types';

const nodes = [
  { cx: 70, cy: 42, label: deliveryTypes[0] },
  { cx: 210, cy: 28, label: deliveryTypes[1] },
  { cx: 350, cy: 42, label: deliveryTypes[2] },
  { cx: 40, cy: 118, label: deliveryTypes[3] },
  { cx: 380, cy: 118, label: deliveryTypes[4] },
  { cx: 70, cy: 192, label: deliveryTypes[5] },
  { cx: 210, cy: 206, label: deliveryTypes[6] },
  { cx: 350, cy: 192, label: deliveryTypes[7] },
  { cx: 130, cy: 88, label: deliveryTypes[8] },
  { cx: 290, cy: 88, label: deliveryTypes[9] },
];
---

<svg class="w-full h-auto max-w-2xl mx-auto" viewBox="0 0 420 240" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <defs>
    <linearGradient id="dn-grad" x1="0" y1="0" x2="420" y2="240">
      <stop offset="0%" stop-color="#14b8a6" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="#f59e0b" stop-opacity="0.08"/>
    </linearGradient>
  </defs>
  <rect width="420" height="240" rx="18" fill="url(#dn-grad)" stroke="#292524" stroke-width="1"/>

  <circle cx="210" cy="118" r="30" fill="#14b8a6" fill-opacity="0.14" stroke="#14b8a6" stroke-width="1.5" stroke-opacity="0.45"/>
  <circle cx="210" cy="118" r="10" fill="#fbbf24" fill-opacity="0.9"/>
  <text x="210" y="122" text-anchor="middle" fill="#1c1917" font-size="7" font-weight="700" font-family="system-ui">KM</text>
  <text x="210" y="168" text-anchor="middle" fill="#a8a29e" font-size="9" font-family="system-ui">Delivery formats I lead</text>

  {nodes.map((n) => (
    <g>
      <line x1="210" y1="118" x2={n.cx} y2={n.cy} stroke="#14b8a6" stroke-width="1" stroke-opacity="0.18"/>
      <rect x={n.cx - 52} y={n.cy - 10} width="104" height="20" rx="10" fill="#1c1917" stroke="#14b8a6" stroke-opacity="0.25" stroke-width="1"/>
      <text x={n.cx} y={n.cy + 4} text-anchor="middle" fill="#d6d3d1" font-size="6.5" font-weight="600" font-family="system-ui">{n.label}</text>
    </g>
  ))}
</svg>
