---
const formats = [
  { icon: '🚀', title: 'Corporate Bootcamps', duration: '1 – 4 weeks', description: 'Intensive data science cohort programs with labs, checkpoints, and a business-context capstone.', ideal: 'Teams needing fast capability lift' },
  { icon: '🏛️', title: 'Enterprise Academies', duration: '3 – 12 months', description: 'Modular tracks with milestone assessments and progressive complexity for L&D-led academies.', ideal: 'Internal data talent pipelines' },
  { icon: '⚡', title: '3–4 Hour Workshops', duration: 'Single session', description: 'Focused sprints on SQL, Power BI, Python, GenAI, or soft skills — one topic, one deliverable.', ideal: 'Busy teams & skill gaps' },
  { icon: '🏗️', title: 'Weekend Project Builds', duration: '2 days', description: 'Ship an app, website, dashboard, or working ML model over a weekend — portfolio-ready output.', ideal: 'Portfolio & hands-on builders' },
  { icon: '🎓', title: 'College Seminars & Webinars', duration: '1 – 3 hrs', description: 'Campus data science seminars, AI literacy talks, and career pathway sessions at DU, AKTU, MDU & more.', ideal: 'Universities & student bodies' },
  { icon: '🎤', title: 'Guest Lectures & On-Demand', duration: 'Flexible', description: 'Bespoke guest lectures, faculty development, and custom sessions on your topic and timeline.', ideal: 'Institutes & event organizers' },
  { icon: '🏆', title: 'Hackathon & Techfest Judging', duration: 'Event-based', description: 'Panel judging and mentorship at university hackathons — helping discover standout talent.', ideal: 'DU, AKTU, MDU & national fests' },
  { icon: '📅', title: 'Workshop Sprints', duration: '1 – 3 days', description: 'Deep-dives on GenAI, SQL, PySpark, or BI — high impact, minimal time away from work.', ideal: 'Specific skill gaps' },
  { icon: '🎯', title: 'Interview Prep & Soft Skills', duration: 'Multi-session', description: 'Mock interviews, communication coaching, and career packaging layered on technical training.', ideal: 'Job-ready graduates & switchers' },
  { icon: '🔄', title: 'Train-the-Trainer', duration: 'Custom', description: 'Curriculum handoff, facilitator guides, and co-delivery for internal champions.', ideal: 'Self-sufficient academies' },
  { icon: '🌐', title: 'Virtual · Hybrid · Onsite', duration: 'Global', description: 'Live virtual, hybrid kickoffs, or in-person intensives across time zones.', ideal: 'Distributed teams' },
];
---

<section id="formats" class="py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal mb-12">
      <p class="section-eyebrow">Engagement formats</p>
      <h2 class="section-heading">Corporate training, your way.</h2>
      <p class="text-stone-500 max-w-2xl mt-2">Bootcamps to 3-hour sprints, campus seminars to hackathon judging — formats that fit your audience and schedule.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {formats.map((f, i) => (
        <div class="reveal card-hover flex flex-col" style={`transition-delay: ${i * 50}ms`}>
          <div class="flex gap-3 mb-3">
            <span class="text-xl">{f.icon}</span>
            <div>
              <h3 class="font-semibold text-stone-100 text-sm">{f.title}</h3>
              <p class="text-[10px] text-brand-400 font-mono">{f.duration}</p>
            </div>
          </div>
          <p class="text-xs text-stone-400 leading-relaxed flex-1 mb-3">{f.description}</p>
          <p class="text-[10px] text-stone-600 border-t border-stone-800 pt-3">Best for: <span class="text-stone-400">{f.ideal}</span></p>
        </div>
      ))}
    </div>

    <div class="reveal mt-12 card p-6 overflow-x-auto">
      <p class="text-[10px] text-stone-500 uppercase tracking-widest font-semibold mb-5">Typical corporate learning path</p>
      <div class="flex items-center gap-0 min-w-max">
        {['Assess', 'Foundations', 'Data Science', 'Applied', 'GenAI', 'Capstone'].map((step, i) => (
          <>
            <div class="flex flex-col items-center gap-1 px-4 py-3 rounded-xl border border-stone-700 bg-stone-800/40 min-w-[88px]">
              <span class="text-[9px] font-mono text-stone-600">0{i + 1}</span>
              <span class="text-xs font-semibold text-stone-200">{step}</span>
            </div>
            {i < 5 && <svg width="16" height="10" viewBox="0 0 20 12" class="text-stone-700 shrink-0"><path d="M0 6h17M12 1l6 5-6 5" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>}
          </>
        ))}
      </div>
    </div>
  </div>
</section>
