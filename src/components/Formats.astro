---
const formats = [
  {
    icon: '🚀',
    title: 'Corporate Bootcamps',
    duration: '1 – 4 weeks',
    description: 'Intensive, cohort-based programs for rapid team upskilling. Full-day or half-day sprints with labs, checkpoints, and a capstone tied to your business context.',
    ideal: 'Engineering & analytics teams needing fast capability lift',
  },
  {
    icon: '🏛️',
    title: 'Enterprise Academies',
    duration: '3 – 12 months',
    description: 'Long-form learning journeys with modular tracks, milestone assessments, and progressive complexity. Designed for L&D-led data & AI academies at scale.',
    ideal: 'Organizations building internal data talent pipelines',
  },
  {
    icon: '📅',
    title: 'Workshop Sprints',
    duration: '1 – 3 days',
    description: 'Focused deep-dives on a single competency — GenAI enablement, SQL mastery, PySpark fundamentals, or BI dashboard excellence. High impact, minimal time away from work.',
    ideal: 'Teams with a specific skill gap to close quickly',
  },
  {
    icon: '🎯',
    title: 'New-Hire Onboarding',
    duration: '2 – 6 weeks',
    description: 'Structured ramp for fresh graduates and lateral hires entering data roles. Standardizes baseline skills before analysts hit production workflows.',
    ideal: 'Growing data orgs with frequent hiring cycles',
  },
  {
    icon: '🔄',
    title: 'Train-the-Trainer',
    duration: 'Custom',
    description: 'Equip your internal champions to sustain learning after the engagement ends. Curriculum handoff, facilitator guides, and co-delivery model.',
    ideal: 'Companies building self-sufficient internal academies',
  },
  {
    icon: '🌐',
    title: 'Virtual · Hybrid · Onsite',
    duration: 'Global delivery',
    description: 'Programs delivered across time zones — live virtual, hybrid with onsite kickoffs, or fully in-person for leadership offsites and team intensives.',
    ideal: 'Distributed teams and multi-country organizations',
  },
];
---

<section id="formats" class="py-24 bg-gray-900/30 border-t border-white/5">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal mb-16">
      <p class="text-brand-400 text-sm font-semibold uppercase tracking-widest mb-3">Engagement formats</p>
      <h2 class="section-heading">Corporate training, your way.</h2>
      <p class="section-subheading mt-3">
        Flexible delivery models designed for how enterprises actually operate — not one-size-fits-all classrooms.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {formats.map((f, i) => (
        <div class="reveal card-hover flex flex-col" style={`transition-delay: ${i * 60}ms`}>
          <div class="flex items-center gap-3 mb-4">
            <span class="text-2xl">{f.icon}</span>
            <div>
              <h3 class="font-semibold text-white text-base">{f.title}</h3>
              <p class="text-xs text-brand-400 font-mono">{f.duration}</p>
            </div>
          </div>
          <p class="text-sm text-gray-400 leading-relaxed mb-4 flex-1">{f.description}</p>
          <div class="border-t border-white/10 pt-4">
            <p class="text-xs text-gray-500 mb-1">Best for</p>
            <p class="text-xs text-gray-300">{f.ideal}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
