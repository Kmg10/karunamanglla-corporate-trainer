---
import { CALENDLY_URL, CALENDLY_CONFIGURED } from '../config';

const headshot = '/assets/karuna-headshot.jpg';

const floatingTags = [
  'Data Science', 'Python', 'SQL', 'PySpark', 'GenAI', 'Tableau', 'ML', 'Power BI',
];
---

<section id="hero" class="min-h-screen flex items-center pt-14 relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_-10%,rgba(20,184,166,0.15),transparent)] pointer-events-none"></div>
  <div class="absolute top-1/4 -right-40 w-[480px] h-[480px] bg-accent-500/6 rounded-full blur-[120px] pointer-events-none"></div>

  <!-- dot grid -->
  <svg class="absolute inset-0 w-full h-full opacity-[0.04] pointer-events-none" aria-hidden="true">
    <defs>
      <pattern id="dots" x="0" y="0" width="28" height="28" patternUnits="userSpaceOnUse">
        <circle cx="2" cy="2" r="1.5" fill="#14b8a6"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#dots)"/>
  </svg>

  <div class="absolute inset-0 overflow-hidden pointer-events-none hidden lg:block" aria-hidden="true">
    {floatingTags.map((tag, i) => (
      <span
        class="absolute text-[10px] font-mono px-2 py-1 rounded-full border border-stone-800 bg-stone-900/60 text-stone-500 animate-float"
        style={`left: ${6 + (i * 11) % 88}%; top: ${10 + (i * 13) % 75}%; animation-delay: ${i * 0.4}s;`}
      >{tag}</span>
    ))}
  </div>

  <div class="max-w-6xl mx-auto px-6 py-16 relative z-10 w-full">
    <div class="grid lg:grid-cols-2 gap-14 items-center">
      <div>
        <span class="chip-accent text-xs mb-6">Corporate Data Science &amp; AI Training</span>

        <h1 class="font-display font-semibold text-5xl md:text-6xl text-stone-50 leading-[1.05] tracking-tight mb-6">
          I don't teach theory.<br />
          I teach what <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-300 via-brand-400 to-accent-400">ships.</span>
        </h1>

        <p class="text-lg text-stone-400 max-w-xl mb-6 leading-relaxed">
          I'm <strong class="text-stone-200">Karuna Manglla</strong> — production Data Science &amp; AI leader and corporate trainer.
          <strong class="text-stone-300"> 5,000+ learners</strong> worldwide, ages 20–50, from fresh graduates to senior professionals.
        </p>
        <p class="text-base text-stone-500 max-w-xl mb-8 leading-relaxed">
          Programs in data science, Python, SQL, PySpark, BI, ML &amp; GenAI — plus interview prep, soft skills,
          and portfolio building to make you absolutely ready for companies and the jobs you want.
        </p>

        <div class="flex flex-wrap gap-2 mb-8">
          <span class="chip-muted text-xs">5,000+ learners globally</span>
          <span class="chip-muted text-xs">4.93+ session rating</span>
          <span class="chip-muted text-xs">Virtual · Hybrid · Onsite</span>
          <span class="chip-muted text-xs">Beginner → Advanced</span>
        </div>

        <div class="flex flex-wrap gap-3">
          <a href={CALENDLY_CONFIGURED ? CALENDLY_URL : '#contact'} target={CALENDLY_CONFIGURED ? '_blank' : undefined} rel={CALENDLY_CONFIGURED ? 'noopener noreferrer' : undefined} class="btn-primary text-sm">Book a discovery call</a>
          <a href="#projects" class="btn-secondary text-sm">Programs</a>
          <a href="#career-ready" class="btn-secondary text-sm">Career readiness</a>
        </div>
      </div>

      <div class="flex flex-col gap-5">
        <div class="relative">
          <div class="absolute -inset-3 bg-gradient-to-br from-brand-500/20 to-accent-500/10 rounded-3xl blur-2xl"></div>
          <img src={headshot} alt="Karuna Manglla" class="relative w-full max-w-xs mx-auto rounded-2xl object-cover aspect-[4/5] border border-stone-700 shadow-2xl"/>
          <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 chip-brand text-xs whitespace-nowrap shadow-lg">
            Open for corporate engagements
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); opacity: 0.4; }
    50% { transform: translateY(-10px); opacity: 0.7; }
  }
  .animate-float { animation: float 5s ease-in-out infinite; }
</style>
