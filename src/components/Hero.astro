---
import { PORTFOLIO_URL } from '../config';

const headshot = '/assets/karuna-headshot.jpg';
---

<section id="hero" class="min-h-[92vh] flex items-center pt-14 relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_-10%,rgba(20,184,166,0.18),transparent)] pointer-events-none"></div>
  <div class="absolute top-1/3 -right-32 w-96 h-96 bg-accent-500/8 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="max-w-5xl mx-auto px-6 py-16 relative z-10 w-full">
    <div class="grid lg:grid-cols-[1.2fr_0.8fr] gap-12 items-center">
      <div>
        <span class="chip-accent text-xs mb-6">Corporate Data Science &amp; AI Trainer</span>

        <h1 class="font-display font-semibold text-5xl md:text-6xl lg:text-7xl text-stone-50 leading-[1.05] tracking-tight mb-6">
          Upskill teams.<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-300 via-brand-400 to-accent-400">Ship outcomes.</span>
        </h1>

        <p class="text-lg text-stone-400 max-w-lg mb-8 leading-relaxed">
          <strong class="text-stone-200">Karuna Manglla</strong> — 5,000+ learners trained globally (ages 20–50).
          Python, SQL, PySpark, BI, ML &amp; GenAI. Built for L&amp;D leaders who need results, not slide decks.
        </p>

        <div class="flex flex-wrap gap-2 mb-8">
          <span class="chip-muted text-xs">Virtual · Hybrid · Onsite</span>
          <span class="chip-muted text-xs">Beginner → Advanced</span>
          <span class="chip-muted text-xs">7+ yrs production ML</span>
        </div>

        <div class="flex flex-wrap gap-3">
          <a href="#contact" class="btn-primary text-sm">Discuss a program</a>
          <a href="#projects" class="btn-secondary text-sm">See signature projects</a>
          <a href={PORTFOLIO_URL} target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm">Work portfolio ↗</a>
        </div>
      </div>

      <div class="hidden lg:block">
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-br from-brand-500/20 to-accent-500/10 rounded-3xl blur-2xl"></div>
          <img
            src={headshot}
            alt="Karuna Manglla"
            class="relative w-full max-w-sm mx-auto rounded-2xl object-cover aspect-[4/5] border border-stone-700 shadow-2xl"
          />
          <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 chip-brand text-xs whitespace-nowrap shadow-lg">
            Open for corporate engagements
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
