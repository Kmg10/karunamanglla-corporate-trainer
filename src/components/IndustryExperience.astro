---
const role = {
  title: 'Data Science & AI Manager',
  company: 'JioStar (Disney+ Hotstar)',
  period: 'Jan 2022 – Present · Promoted 3× in 4 years',
  scale: '500M+ users · 800M+ records/day · 5 live ML systems',
  summary: 'I don\'t just teach data science — I run it at India\'s largest streaming platform. Every training program is informed by systems that land in boardroom decisions.',
};

const productionProjects = [
  { line: '12-dimensional LTV engine → greenlit the first price hike in 7 years (+50%), lifting net profitability 20%.', tag: 'Revenue' },
  { line: 'Bayesian Marketing Mix Model → cut total marketing spend 30% with zero revenue impact — now the C-suite standard.', tag: 'MMM' },
  { line: 'Content ROI v2 → CEO-directed company standard for every content green-light and performance review.', tag: 'Strategy' },
  { line: 'Personalised discount engine → saved 30% of annual discount spend across 3M+ subscriber cohorts.', tag: 'ML' },
  { line: '6-horizon churn prediction → converted 40% of at-risk users in production retention workflows.', tag: 'Retention' },
  { line: 'EMR → Databricks migration → 17× pipeline speedup processing 800M+ records daily.', tag: 'Engineering' },
  { line: 'LLM-powered content discovery → company-wide hackathon 2nd Runner-Up, CEO-recognised.', tag: 'GenAI' },
];
---

<section id="industry" class="py-20 border-y border-stone-800/80 bg-gradient-to-b from-brand-950/20 to-transparent">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal mb-10">
      <p class="section-eyebrow">Industry experience</p>
      <h2 class="section-heading">What I build when I'm not in the classroom.</h2>
    </div>

    <!-- Role card -->
    <div class="reveal card border-brand-500/25 bg-brand-950/15 p-6 md:p-8 mb-8">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <p class="text-[10px] uppercase tracking-widest text-brand-400 font-semibold mb-1">Current role</p>
          <h3 class="font-display text-2xl md:text-3xl text-stone-50 font-semibold">{role.title}</h3>
          <p class="text-brand-300 font-medium mt-1">{role.company}</p>
          <p class="text-xs text-stone-500 mt-2 font-mono">{role.period}</p>
        </div>
        <div class="md:text-right">
          <p class="text-sm text-stone-400 font-medium">{role.scale}</p>
          <p class="text-xs text-stone-500 mt-2 max-w-xs md:ml-auto leading-relaxed">{role.summary}</p>
        </div>
      </div>
    </div>

    <!-- One-line production projects -->
    <div class="reveal space-y-2">
      <p class="text-[10px] uppercase tracking-widest text-stone-500 font-semibold mb-4">Production systems · one line each</p>
      {productionProjects.map((p, i) => (
        <div
          class="group flex items-start gap-4 px-4 py-3.5 rounded-xl border border-stone-800/80 bg-stone-900/40 hover:border-brand-500/30 hover:bg-stone-900/70 transition-all"
          style={`transition-delay: ${i * 30}ms`}
        >
          <span class="chip-muted text-[9px] shrink-0 mt-0.5">{p.tag}</span>
          <p class="text-sm text-stone-300 leading-snug group-hover:text-stone-100 transition-colors">
            <span class="text-brand-400 mr-1">→</span>{p.line}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
