---
const topics = [
  { name: 'Python', icon: '🐍' },
  { name: 'SQL', icon: '🗄️' },
  { name: 'PySpark', icon: '⚡' },
  { name: 'Business Intelligence', icon: '📊' },
  { name: 'Data Analysis', icon: '📈' },
  { name: 'Machine Learning', icon: '🤖' },
  { name: 'LLMs & GenAI', icon: '✨' },
  { name: 'Tools & MLOps', icon: '🛠️' },
];

const formats = ['Bootcamps', 'Enterprise Academies', 'Workshop Sprints', 'Train-the-Trainer'];
---

<section id="curriculum" class="py-20">
  <div class="max-w-5xl mx-auto px-6">
    <div class="reveal mb-10">
      <p class="section-eyebrow">What I teach</p>
      <h2 class="section-heading">Full-stack data &amp; AI.</h2>
    </div>

    <div class="reveal grid grid-cols-2 md:grid-cols-4 gap-3 mb-10">
      {topics.map((t, i) => (
        <div class="card text-center py-5 hover:border-brand-500/30 transition-colors" style={`transition-delay: ${i * 40}ms`}>
          <span class="text-2xl block mb-2">{t.icon}</span>
          <span class="text-sm text-stone-300 font-medium">{t.name}</span>
        </div>
      ))}
    </div>

    <div class="reveal flex flex-wrap gap-2 justify-center">
      {formats.map(f => (
        <span class="chip-brand text-xs">{f}</span>
      ))}
    </div>
  </div>
</section>
