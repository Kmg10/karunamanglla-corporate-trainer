---
const orgs = [
  { name: 'upGrad', logo: '/assets/logos/upgrad.svg', tagline: 'Professional upskilling at scale', role: 'Data Science & AI programs for working professionals', accent: 'border-orange-500/20 bg-orange-950/20' },
  { name: 'Coding Ninjas', logo: '/assets/logos/coding-ninjas.svg', tagline: "India's leading coding education platform", role: 'Python, DSA, data science & ML cohorts — campus to corporate', accent: 'border-violet-500/20 bg-violet-950/20' },
  { name: 'BITS Pilani', logo: '/assets/logos/bits-pilani.svg', tagline: 'Premier institute · Work-integrated learning', role: 'Advanced analytics & data science for degree learners', accent: 'border-sky-500/20 bg-sky-950/20' },
  { name: 'Info Edge', logo: '/assets/logos/info-edge.svg', tagline: 'Naukri.com · AI-first product company', role: 'SQL, BI & data literacy for product & analytics teams', accent: 'border-blue-500/20 bg-blue-950/20' },
  { name: 'Madrid Solutions', logo: '/assets/logos/madrid-solutions.svg', tagline: 'Madrid Software Training Solutions', role: 'Full-stack data engineering & cloud analytics bootcamps', accent: 'border-brand-500/25 bg-brand-950/25' },
  { name: 'Edwisor', logo: '/assets/logos/edwisor.svg', tagline: 'Career acceleration & live industry projects', role: 'Data Science mentorship & job-ready skill programs', accent: 'border-pink-500/20 bg-pink-950/20' },
  { name: 'Datafolkz', logo: '/assets/logos/datafolkz.svg', tagline: 'Data science community & corporate training', role: 'Analytics workshops, ML sprints & practitioner upskilling', accent: 'border-lime-500/20 bg-lime-950/20' },
];
---

<section id="orgs" class="py-20 border-y border-stone-800/80 bg-stone-900/20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal mb-12">
      <p class="section-eyebrow">Trusted by</p>
      <h2 class="section-heading">Organizations I've trained with.</h2>
      <p class="text-stone-500 max-w-2xl mt-2">Edtech leaders, premier institutes, and enterprise L&amp;D partners — across India and global virtual cohorts.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {orgs.map((org, i) => (
        <div class={`reveal p-5 rounded-2xl border ${org.accent} hover:border-brand-500/30 transition-colors`} style={`transition-delay: ${i * 40}ms`}>
          <div class="flex items-center gap-3 mb-3">
            <div class="w-14 h-10 rounded-lg bg-white flex items-center justify-center shrink-0 overflow-hidden border border-stone-200/20 px-2">
              <img
                src={org.logo}
                alt={`${org.name} logo`}
                class="max-h-8 max-w-full object-contain"
                loading="lazy"
                draggable="false"
              />
            </div>
            <h3 class="font-display text-xl text-stone-50 font-semibold">{org.name}</h3>
          </div>
          <p class="text-[11px] text-stone-500 uppercase tracking-wider">{org.tagline}</p>
          <p class="text-sm text-stone-400 mt-3 leading-relaxed">{org.role}</p>
        </div>
      ))}
    </div>
  </div>
</section>
