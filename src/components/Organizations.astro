---
import { partners } from '../data/partners';

const marqueeItems = [...partners, ...partners];
---

<section id="orgs" class="py-20 border-y border-stone-800/80 overflow-hidden relative">
  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="reveal mb-10 text-center md:text-left">
      <p class="section-eyebrow">Trusted by</p>
      <h2 class="section-heading">Organizations I've trained with.</h2>
      <p class="text-stone-500 max-w-2xl mt-2 mx-auto md:mx-0">
        Edtech leaders, IIT partnerships, premier institutes, and enterprise L&amp;D partners — across India and global virtual cohorts.
      </p>
    </div>

    <div class="reveal relative partner-marquee-wrap">
      <div class="absolute left-0 top-0 bottom-0 w-16 sm:w-24 bg-gradient-to-r from-stone-950 to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-16 sm:w-24 bg-gradient-to-l from-stone-950 to-transparent z-10 pointer-events-none"></div>

      <div class="partner-marquee-track">
        {marqueeItems.map((org) => (
          <div class="partner-marquee-item" title={org.name}>
            <img
              src={org.logo}
              alt={`${org.name} logo`}
              width={org.width}
              height={org.height}
              class="partner-logo"
              loading="eager"
              decoding="async"
              draggable="false"
            />
            <span class="partner-name">{org.shortName}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .partner-marquee-wrap {
    padding: 0.5rem 0 1rem;
  }

  .partner-marquee-track {
    display: flex;
    align-items: flex-start;
    gap: 3.5rem;
    width: max-content;
    animation: partner-scroll 55s linear infinite;
  }

  .partner-marquee-track:hover {
    animation-play-state: paused;
  }

  .partner-marquee-item {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.875rem;
    min-width: max-content;
  }

  .partner-logo {
    display: block;
    width: auto;
    height: auto;
    max-width: none;
    object-fit: contain;
    image-rendering: auto;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  .partner-name {
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgb(168 162 158);
    text-align: center;
    line-height: 1.3;
    white-space: nowrap;
  }

  @keyframes partner-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .partner-marquee-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      gap: 2rem 2.5rem;
    }
  }
</style>
