---
const projects = [
  {
    org: 'upGrad', title: 'Enterprise Data Science Accelerator', hook: 'Zero to production-ready in 12 weeks.',
    outcome: 'Working professionals — analysts, engineers, PMs — shipped capstone projects on real business datasets. Python → SQL → ML → stakeholder presentation.',
    tags: ['Python', 'SQL', 'Machine Learning', 'Capstone'], stat: 'Multi-cohort', accent: 'border-orange-500/20',
  },
  {
    org: 'Coding Ninjas', title: 'GenAI Practitioner Bootcamp', hook: 'LLMs teams use on Monday.',
    outcome: 'Prompt engineering, RAG pipelines, and AI agents for developers and data professionals entering the GenAI wave.',
    tags: ['LLMs', 'RAG', 'GenAI', 'Python'], stat: 'Bootcamp', accent: 'border-violet-500/20',
  },
  {
    org: 'BITS Pilani', title: 'Advanced Analytics for Professionals', hook: 'Rigour of BITS. Relevance of industry.',
    outcome: 'Statistics, EDA, and predictive modeling for WIL learners — academic foundations meets corporate-grade workflows.',
    tags: ['Statistics', 'EDA', 'Predictive Modeling'], stat: 'WIL program', accent: 'border-sky-500/20',
  },
  {
    org: 'Info Edge', title: 'Product Analytics Upskilling Sprint', hook: 'Data fluency at scale.',
    outcome: 'SQL mastery, dashboard design, and metric frameworks for product managers and analysts at Naukri\'s parent company.',
    tags: ['SQL', 'BI', 'Product Analytics'], stat: 'L&D sprint', accent: 'border-blue-500/20',
  },
  {
    org: 'Madrid Solutions', title: 'Data Engineering & PySpark Cohort', hook: 'Laptops to cluster-scale.',
    outcome: 'PySpark, ETL design, and Databricks workflows for enterprise IT trainees — analyst skills to engineering-grade pipelines.',
    tags: ['PySpark', 'Databricks', 'ETL'], stat: 'Enterprise series', accent: 'border-brand-500/25',
  },
  {
    org: 'Edwisor', title: 'Career-Ready Data Science Program', hook: 'Industry projects. Interview confidence.',
    outcome: 'End-to-end data science mentorship — from Python foundations to portfolio projects and mock interviews for career switchers and fresh graduates.',
    tags: ['Python', 'ML', 'Projects', 'Mentorship'], stat: 'Career program', accent: 'border-pink-500/20',
  },
  {
    org: 'Datafolkz', title: 'Corporate Analytics Workshop Series', hook: 'Community rigour. Corporate pace.',
    outcome: 'Intensive analytics and ML workshops for practitioners — hands-on sessions on real datasets with immediate application to client work.',
    tags: ['Analytics', 'ML', 'Workshops', 'SQL'], stat: 'Workshop series', accent: 'border-lime-500/20',
  },
];
---

<section id="projects" class="py-20 bg-stone-900/25 border-y border-stone-800/80">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal mb-12">
      <p class="section-eyebrow">Signature projects</p>
      <h2 class="section-heading">Programs that persuade.</h2>
      <p class="text-stone-500 max-w-2xl mt-2">Representative engagements — each built around business outcomes, not syllabus checklists.</p>
    </div>

    <div class="space-y-4">
      {projects.map((p, i) => (
        <article class={`reveal group rounded-2xl border ${p.accent} bg-stone-900/50 p-6 md:p-7 hover:border-brand-500/30 transition-all`} style={`transition-delay: ${i * 40}ms`}>
          <div class="grid md:grid-cols-[200px_1fr_auto] gap-5 items-start">
            <div>
              <span class="text-[10px] font-semibold uppercase tracking-widest text-brand-400">{p.org}</span>
              <h3 class="font-display text-xl text-stone-50 font-semibold mt-1 leading-snug">{p.title}</h3>
              <p class="text-accent-400 text-xs mt-1 italic">{p.hook}</p>
            </div>
            <p class="text-sm text-stone-400 leading-relaxed">{p.outcome}</p>
            <div class="flex flex-col items-start md:items-end gap-2">
              <span class="text-[10px] uppercase tracking-widest text-stone-600">{p.stat}</span>
              <div class="flex flex-wrap gap-1.5 md:justify-end">
                {p.tags.map(t => <span class="chip-muted text-[10px]">{t}</span>)}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
