---
import { SESSION_RATING } from '../config';

const projects = [
  {
    org: 'upGrad', title: 'Enterprise Data Science Accelerator', hook: 'Zero to production-ready in 12 weeks.',
    outcome: 'Working professionals — analysts, engineers, PMs — shipped capstone projects on real business datasets. Python → SQL → data science → ML → stakeholder presentation.',
    tags: ['Data Science', 'Python', 'SQL', 'ML', 'Capstone'], stat: 'Multi-cohort', accent: 'border-orange-500/20',
  },
  {
    org: 'Coding Ninjas', title: 'GenAI Practitioner Bootcamp', hook: 'LLMs teams use on Monday.',
    outcome: 'Prompt engineering, RAG pipelines, and AI agents for developers and data professionals entering the GenAI wave.',
    tags: ['LLMs', 'RAG', 'GenAI', 'Data Science'], stat: 'Bootcamp', accent: 'border-violet-500/20',
  },
  {
    org: 'Edwisor', title: 'Interview Prep & Soft Skills Intensive', hook: 'Job-ready, not just skill-ready.',
    outcome: 'Mock interviews, behavioral rounds, stakeholder communication, and salary negotiation — layered on top of technical data science training.',
    tags: ['Interview prep', 'Soft skills', 'Mock interviews', 'Career'], stat: 'Career program', accent: 'border-pink-500/20',
  },
  {
    org: 'Coding Ninjas', title: 'Weekend Project Workshop', hook: 'Ship an app, website, or working model in 2 days.',
    outcome: 'Hands-on build sprints — learners leave with a deployed portfolio piece: web apps, dashboards, ML demos, or working prototypes over a weekend.',
    tags: ['Portfolio', 'Web app', 'Working models', 'Weekend sprint'], stat: '2-day workshop', accent: 'border-violet-500/20',
  },
  {
    org: 'Madrid Solutions', title: '3–4 Hour Skills Sprint', hook: 'High impact in a single afternoon.',
    outcome: 'Focused deep-dives on SQL, Power BI, Python, or GenAI — one concept, one outcome, one deliverable by end of session.',
    tags: ['SQL', 'Power BI', 'Python', 'GenAI'], stat: '3–4 hr sprint', accent: 'border-brand-500/25',
  },
  {
    org: 'University partnerships', title: 'College Seminars & Webinars', hook: 'Campus to career bridge.',
    outcome: 'Data science, AI literacy, and career pathway seminars for undergraduates — delivered at DU, AKTU, MDU, and partner universities across India.',
    tags: ['Seminars', 'Webinars', 'DU', 'AKTU', 'MDU'], stat: 'Campus outreach', accent: 'border-sky-500/20',
  },
  {
    org: 'On demand', title: 'Guest Lectures & Custom Sessions', hook: 'Your topic, your timeline.',
    outcome: 'Bespoke guest lectures, faculty development sessions, and on-demand workshops tailored to institute or corporate needs.',
    tags: ['Guest lecture', 'On demand', 'Custom', 'Faculty'], stat: 'Flexible', accent: 'border-amber-500/20',
  },
  {
    org: 'Hackathons & techfests', title: 'Judge & Talent Discovery', hook: 'Finding tomorrow\'s builders today.',
    outcome: 'Judging panels and mentorship at university hackathons and techfests — identifying standout talent and guiding project evaluation at DU, AKTU, MDU, and national events.',
    tags: ['Hackathons', 'Techfests', 'Judging', 'Talent discovery'], stat: 'University events', accent: 'border-emerald-500/20',
  },
  {
    org: 'BITS Pilani', title: 'Advanced Analytics for Professionals', hook: 'Rigour of BITS. Relevance of industry.',
    outcome: 'Statistics, EDA, and predictive modeling for WIL learners — academic foundations meets corporate-grade data science workflows.',
    tags: ['Statistics', 'EDA', 'Data Science', 'Predictive Modeling'], stat: 'WIL program', accent: 'border-sky-500/20',
  },
  {
    org: 'Info Edge', title: 'Product Analytics Upskilling Sprint', hook: 'Data fluency at scale.',
    outcome: 'SQL mastery, dashboard design, and metric frameworks for product managers and analysts at Naukri\'s parent company.',
    tags: ['SQL', 'BI', 'Product Analytics'], stat: 'L&D sprint', accent: 'border-blue-500/20',
  },
  {
    org: 'Datafolkz', title: 'Corporate Analytics Workshop Series', hook: 'Community rigour. Corporate pace.',
    outcome: 'Intensive analytics and ML workshops for practitioners — hands-on sessions on real datasets with immediate application to client work.',
    tags: ['Analytics', 'ML', 'Workshops', 'SQL'], stat: 'Workshop series', accent: 'border-lime-500/20',
  },
];
---

<section id="projects" class="py-20 bg-stone-900/25 border-y border-stone-800/80">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal mb-12">
      <p class="section-eyebrow">Signature projects</p>
      <h2 class="section-heading">Programs that persuade.</h2>
      <p class="text-stone-500 max-w-2xl mt-2">
        Representative engagements — data science bootcamps, soft skills, interview prep, weekend project builds,
        campus seminars, hackathon judging, and on-demand guest lectures.
        <span class="text-brand-400 font-semibold">{SESSION_RATING}+</span> out of 5 average learner rating.
      </p>
    </div>

    <div class="space-y-4">
      {projects.map((p, i) => (
        <article class={`reveal group rounded-2xl border ${p.accent} bg-stone-900/50 p-6 md:p-7 hover:border-brand-500/30 transition-all`} style={`transition-delay: ${i * 40}ms`}>
          <div class="grid md:grid-cols-[200px_1fr_auto] gap-5 items-start">
            <div>
              <span class="text-[10px] font-semibold uppercase tracking-widest text-brand-400">{p.org}</span>
              <h3 class="font-display text-xl text-stone-50 font-semibold mt-1 leading-snug">{p.title}</h3>
              <p class="text-accent-400 text-xs mt-1 italic">{p.hook}</p>
            </div>
            <p class="text-sm text-stone-400 leading-relaxed">{p.outcome}</p>
            <div class="flex flex-col items-start md:items-end gap-2">
              <span class="text-[10px] uppercase tracking-widest text-stone-600">{p.stat}</span>
              <div class="flex flex-wrap gap-1.5 md:justify-end">
                {p.tags.map(t => <span class="chip-muted text-[10px]">{t}</span>)}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
