---
import { learnerEmployers, industrySectors } from '../data/learner-industries';

const marqueeItems = [...learnerEmployers, ...learnerEmployers];
---

<section id="learner-industries" class="py-16 border-y border-stone-800/80 bg-stone-900/15 overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal mb-8 text-center">
      <p class="section-eyebrow">Cross-industry reach</p>
      <h2 class="font-display text-2xl md:text-3xl text-stone-50 font-semibold mb-2">
        Working professionals from leading organizations.
      </h2>
      <p class="text-stone-500 text-sm max-w-2xl mx-auto">
        Learners across technology, banking, healthcare, consumer electronics, and more — from fresh graduates to senior professionals.
      </p>
      <div class="flex flex-wrap justify-center gap-2 mt-4">
        {industrySectors.map((sector) => (
          <span class="chip-muted text-[10px]">{sector}</span>
        ))}
      </div>
    </div>

    <div class="reveal relative employer-marquee-wrap">
      <div class="absolute left-0 top-0 bottom-0 w-16 bg-gradient-to-r from-stone-950 to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-16 bg-gradient-to-l from-stone-950 to-transparent z-10 pointer-events-none"></div>
      <div class="employer-marquee-track">
        {marqueeItems.map((emp) => (
          <div class="employer-marquee-item" title={`${emp.name} — ${emp.industry}`}>
            <img
              src={emp.logo}
              alt={`${emp.name} logo`}
              width={emp.width}
              height={emp.height}
              class="employer-logo"
              loading="lazy"
              draggable="false"
            />
            <div class="text-center">
              <p class="text-sm font-medium text-stone-300">{emp.name}</p>
              <p class="text-[11px] text-stone-500">{emp.industry}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .employer-marquee-track {
    display: flex;
    align-items: flex-start;
    gap: 4rem;
    width: max-content;
    animation: employer-scroll 40s linear infinite;
  }
  .employer-marquee-track:hover { animation-play-state: paused; }
  .employer-marquee-item {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    min-width: max-content;
  }
  .employer-logo {
    display: block;
    opacity: 0.92;
  }
  @keyframes employer-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .employer-marquee-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      gap: 2rem;
    }
  }
</style>
