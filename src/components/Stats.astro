---
const stats = [
  {
    value: 5000,
    suffix: '+',
    label: 'Learners trained worldwide',
    description: 'College graduates to working professionals across global cohorts',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    gradient: 'from-brand-500/20 to-transparent',
    border: 'border-brand-500/30',
    iconColor: 'text-brand-400',
  },
  {
    value: 7,
    suffix: '+',
    label: 'Years in production data science',
    description: 'Real systems at 500M+ user scale — not classroom hypotheticals',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    gradient: 'from-purple-500/20 to-transparent',
    border: 'border-purple-500/30',
    iconColor: 'text-purple-400',
  },
  {
    value: 15,
    suffix: '+',
    label: 'Competency areas covered',
    description: 'Python through GenAI — full-stack data & AI curriculum',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2 2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
    gradient: 'from-emerald-500/20 to-transparent',
    border: 'border-emerald-500/30',
    iconColor: 'text-emerald-400',
  },
  {
    value: 3,
    suffix: '',
    label: 'Skill tiers per program',
    description: 'Foundational, practitioner, and advanced — role-mapped paths',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m3 17 6-6 4 4 8-8"/><path d="M14 7h7v7"/></svg>`,
    gradient: 'from-cyan-500/20 to-transparent',
    border: 'border-cyan-500/30',
    iconColor: 'text-cyan-400',
  },
  {
    value: 30,
    suffix: '',
    label: 'Years of learner age range',
    description: 'Professionals aged 20–50 across every career stage',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
    gradient: 'from-accent-500/20 to-transparent',
    border: 'border-accent-500/30',
    iconColor: 'text-orange-400',
  },
  {
    value: 100,
    suffix: '%',
    label: 'Hands-on delivery',
    description: 'Labs, capstones, and business-relevant exercises — not slide decks',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
    gradient: 'from-rose-500/20 to-transparent',
    border: 'border-rose-500/30',
    iconColor: 'text-rose-400',
  },
];
---

<section id="impact" class="py-24 relative overflow-hidden border-t border-white/5">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-brand-900/8 to-transparent pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal mb-16">
      <p class="text-brand-400 text-sm font-semibold uppercase tracking-widest mb-3">Training impact</p>
      <h2 class="section-heading">Built for corporate outcomes — not certificates on a wall.</h2>
      <p class="section-subheading mt-3">
        Every metric below reflects a training practice designed for L&amp;D leaders, engineering managers,
        and organizations that need measurable upskilling — not vanity workshops.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {stats.map((stat, i) => (
        <div
          class={`reveal group relative overflow-hidden rounded-2xl border bg-gradient-to-br ${stat.gradient} ${stat.border} p-6 hover:-translate-y-1 transition-all duration-300 hover:shadow-xl`}
          style={`transition-delay: ${i * 70}ms`}
        >
          <div class={`${stat.iconColor} mb-4 opacity-90`} set:html={stat.icon} />
          <div class="text-4xl md:text-5xl font-display font-bold text-white mb-2 tabular-nums">
            <span data-counter data-target={stat.value} data-suffix={stat.suffix}>
              0{stat.suffix}
            </span>
          </div>
          <div class="font-semibold text-gray-200 mb-1.5">{stat.label}</div>
          <p class="text-sm text-gray-500 leading-relaxed">{stat.description}</p>
          <div class={`absolute -bottom-6 -right-6 w-24 h-24 rounded-full blur-2xl opacity-30 bg-current ${stat.iconColor}`}></div>
        </div>
      ))}
    </div>
  </div>
</section>
