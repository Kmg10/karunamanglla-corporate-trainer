---
const stats = [
  { value: 5000, suffix: '+', label: 'Learners trained' },
  { value: 7, suffix: '+', label: 'Years in production DS/AI' },
  { value: 15, suffix: '+', label: 'Competency areas' },
  { value: 5, suffix: '', label: 'Major training partners' },
];
---

<section id="impact" class="py-14 border-y border-stone-800/80 bg-stone-900/30">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {stats.map((s, i) => (
        <div class="reveal text-center" style={`transition-delay: ${i * 60}ms`}>
          <div class="text-3xl md:text-4xl font-display font-semibold text-stone-50 tabular-nums">
            <span data-counter data-target={s.value} data-suffix={s.suffix}>0{s.suffix}</span>
          </div>
          <p class="text-xs text-stone-500 mt-1 uppercase tracking-wider">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
