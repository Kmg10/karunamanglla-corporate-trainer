---
import { CALENDLY_URL } from '../config';
---

<section id="contact" class="py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal grid lg:grid-cols-2 gap-8 items-start">
      <div class="card p-8 md:p-10 border-brand-500/20 bg-gradient-to-b from-brand-950/30 to-stone-900/60">
        <p class="section-eyebrow">Let's talk</p>
        <h2 class="font-display text-3xl md:text-4xl text-stone-50 font-semibold mb-3">
          Build your next cohort.
        </h2>
        <p class="text-stone-400 text-sm mb-2">
          GenAI sprint, data academy, or custom bootcamp — share your team, stack, and timeline.
        </p>
        <p class="text-stone-600 text-xs mb-6">
          Typical first call: skill level, target competencies, delivery preference (virtual / hybrid / onsite).
        </p>

        <div class="flex flex-wrap gap-3 mb-6">
          <a href={CALENDLY_URL} target="_blank" rel="noopener noreferrer" class="btn-primary text-sm">
            Book a slot
          </a>
          <a href="mailto:karuna.mangla@gmail.com?subject=Corporate%20Training%20Inquiry" class="btn-secondary text-sm">
            Email Karuna
          </a>
          <a href="https://www.linkedin.com/in/karuna-mangla" target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm">
            LinkedIn
          </a>
        </div>

        <div class="flex flex-wrap gap-2">
          <span class="chip-muted text-[10px]">Python · SQL · PySpark</span>
          <span class="chip-muted text-[10px]">BI · ML · GenAI</span>
          <span class="chip-muted text-[10px]">5,000+ learners</span>
        </div>
      </div>

      <div class="reveal card p-4 md:p-6 overflow-hidden">
        <p class="text-xs font-semibold text-stone-400 uppercase tracking-wider mb-4 px-2">Schedule a discovery call</p>
        <div class="calendly-inline-widget rounded-xl overflow-hidden" data-url={`${CALENDLY_URL}?hide_gdpr_banner=1&background_color=1c1917&text_color=e7e5e4&primary_color=14b8a6`} style="min-width:280px;height:580px;"></div>
      </div>
    </div>
  </div>
</section>

<script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
