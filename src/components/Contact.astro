---
import { CALENDLY_URL, CALENDLY_CONFIGURED } from '../config';

const calendlyEmbed = CALENDLY_CONFIGURED
  ? `${CALENDLY_URL}?hide_gdpr_banner=1&background_color=1c1917&text_color=e7e5e4&primary_color=14b8a6`
  : '';
---

<section id="contact" class="py-20 allow-select">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal grid lg:grid-cols-2 gap-8 items-start">
      <div class="card p-8 md:p-10 border-brand-500/20 bg-gradient-to-b from-brand-950/30 to-stone-900/60">
        <p class="section-eyebrow">Let's talk</p>
        <h2 class="font-display text-3xl md:text-4xl text-stone-50 font-semibold mb-3">
          Build your next cohort.
        </h2>
        <p class="text-stone-400 text-sm mb-2">
          GenAI sprint, data academy, campus seminar, or custom bootcamp — share your team, stack, and timeline.
        </p>
        <p class="text-stone-600 text-xs mb-6">
          Typical first call: skill level, target competencies, delivery preference (virtual / hybrid / onsite).
        </p>

        <div class="flex flex-wrap gap-3 mb-6">
          {CALENDLY_CONFIGURED ? (
            <>
              <button type="button" id="calendly-popup-btn" class="btn-primary text-sm cursor-pointer">
                Book a slot
              </button>
              <a href={CALENDLY_URL} target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm">
                Open Calendly
              </a>
            </>
          ) : (
            <a href="mailto:karuna.mangla@gmail.com?subject=Book%20a%20Discovery%20Call%20—%20Corporate%20Training" class="btn-primary text-sm">
              Book via email
            </a>
          )}
          <a href="mailto:karuna.mangla@gmail.com?subject=Corporate%20Training%20Inquiry" class="btn-secondary text-sm">
            Email Karuna
          </a>
          <a href="https://www.linkedin.com/in/karuna-mangla" target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm">
            LinkedIn
          </a>
        </div>

        {!CALENDLY_CONFIGURED && (
          <div class="rounded-xl border border-amber-500/20 bg-amber-950/20 p-4 mb-4 text-xs text-stone-400 leading-relaxed">
            <p class="text-amber-300/90 font-semibold mb-1">Calendly coming soon</p>
            <p>Online scheduling will be live once Calendly is connected. For now, email <a href="mailto:karuna.mangla@gmail.com" class="text-brand-400 hover:underline">karuna.mangla@gmail.com</a> to book a discovery call.</p>
          </div>
        )}

        <div class="flex flex-wrap gap-2">
          <span class="chip-muted text-[10px]">Data Science · Python · SQL</span>
          <span class="chip-muted text-[10px]">BI · ML · GenAI</span>
          <span class="chip-muted text-[10px]">4.93+ rating</span>
        </div>
      </div>

      <div class="reveal card p-4 md:p-6 overflow-hidden min-h-[480px]">
        {CALENDLY_CONFIGURED ? (
          <>
            <p class="text-xs font-semibold text-stone-400 uppercase tracking-wider mb-3 px-2">Schedule a discovery call</p>
            <iframe
              src={calendlyEmbed}
              title="Schedule a call with Karuna Manglla"
              class="w-full rounded-xl border-0 bg-stone-900"
              style="height:520px;min-height:520px;"
              loading="lazy"
            ></iframe>
          </>
        ) : (
          <div class="flex flex-col items-center justify-center h-full min-h-[420px] text-center px-6 py-10">
            <div class="w-16 h-16 rounded-2xl bg-brand-500/15 border border-brand-500/25 flex items-center justify-center text-3xl mb-5">📅</div>
            <h3 class="font-display text-xl text-stone-100 font-semibold mb-2">Book a discovery call</h3>
            <p class="text-sm text-stone-500 mb-6 max-w-sm">
              Send an email with your team size, topics (data science, GenAI, soft skills, etc.), and preferred dates. I'll reply within 24 hours.
            </p>
            <a
              href="mailto:karuna.mangla@gmail.com?subject=Book%20a%20Discovery%20Call&body=Hi%20Karuna%2C%0A%0AI%27d%20like%20to%20book%20a%20discovery%20call.%0A%0ATeam%20size%3A%20%0ATopics%3A%20%0APreferred%20dates%3A%20%0A%0AThanks!"
              class="btn-primary text-sm"
            >
              Email to schedule
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

{CALENDLY_CONFIGURED && (
  <>
    <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />
    <script is:inline define:vars={{ calendlyUrl: CALENDLY_URL }}>
      function initCalendly() {
        const btn = document.getElementById('calendly-popup-btn');
        if (!btn) return;
        btn.addEventListener('click', () => {
          if (window.Calendly) {
            window.Calendly.initPopupWidget({ url: calendlyUrl });
          } else {
            window.open(calendlyUrl, '_blank', 'noopener,noreferrer');
          }
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCalendly);
      } else {
        initCalendly();
      }
    </script>
    <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
  </>
)}
