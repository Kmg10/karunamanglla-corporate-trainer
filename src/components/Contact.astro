---
import { PORTFOLIO_URL } from '../config';
---

<section id="contact" class="py-24 border-t border-white/5">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal">
      <div class="card bg-gradient-to-br from-brand-900/50 via-gray-900 to-emerald-900/20 border-brand-500/25 text-center max-w-3xl mx-auto p-10 md:p-14">
        <div class="text-4xl mb-6">🤝</div>
        <p class="text-brand-400 text-sm font-semibold uppercase tracking-widest mb-3">Let's build your program</p>
        <h2 class="text-3xl md:text-4xl font-display font-semibold text-white mb-4">
          Ready to upskill your team?
        </h2>
        <p class="text-gray-400 leading-relaxed mb-3 max-w-xl mx-auto">
          Whether you need a GenAI enablement sprint, a full data academy, or a custom bootcamp for 50 analysts —
          let's design a program that maps to your stack, your people, and your business outcomes.
        </p>
        <p class="text-gray-500 text-sm mb-8 max-w-lg mx-auto">
          Typical first conversation: your team's current skill level, target competencies, timeline, and delivery preference (virtual / hybrid / onsite).
        </p>

        <div class="flex flex-wrap gap-4 justify-center mb-8">
          <a href="mailto:karuna.mangla@gmail.com?subject=Corporate%20Data%20Science%20%26%20AI%20Training%20Inquiry" class="btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            Email for corporate training
          </a>
          <a href="https://www.linkedin.com/in/karuna-mangla" target="_blank" rel="noopener noreferrer" class="btn-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            Connect on LinkedIn
          </a>
        </div>

        <div class="flex flex-wrap gap-3 justify-center text-xs text-gray-500">
          <span class="chip-gray">Python · SQL · PySpark</span>
          <span class="chip-gray">BI · Data Analysis</span>
          <span class="chip-gray">ML · GenAI · LLMs</span>
          <span class="chip-gray">5,000+ learners trained</span>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="py-8 border-t border-white/5">
  <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
    <p>© {new Date().getFullYear()} Karuna Manglla · Corporate Data Science &amp; AI Training</p>
    <div class="flex items-center gap-6">
      <a href={PORTFOLIO_URL} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Work Portfolio</a>
      <a href="https://www.linkedin.com/in/karuna-mangla" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">LinkedIn</a>
      <a href="mailto:karuna.mangla@gmail.com" class="hover:text-white transition-colors">Email</a>
    </div>
  </div>
</footer>
