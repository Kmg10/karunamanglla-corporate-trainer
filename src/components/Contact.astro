    <div class="flex gap-5">
      <a href="https://www.linkedin.com/in/karuna-mangla" target="_blank" rel="noopener noreferrer" class="hover:text-stone-400 transition-colors">LinkedIn</a>
      <a href="mailto:karuna.mangla@gmail.com" class="hover:text-stone-400 transition-colors">Email</a>
    </div>
  </div>
</footer>
