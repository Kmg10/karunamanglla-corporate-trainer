<section id="contact" class="py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal card text-center max-w-2xl mx-auto p-10 md:p-12 border-brand-500/20 bg-gradient-to-b from-brand-950/30 to-stone-900/60">
      <p class="section-eyebrow">Let's talk</p>
      <h2 class="font-display text-3xl md:text-4xl text-stone-50 font-semibold mb-3">
        Build your next cohort.
      </h2>
      <p class="text-stone-400 text-sm mb-2 max-w-md mx-auto">
